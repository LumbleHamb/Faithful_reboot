; Engine configuration file.
; It's best edited using the editor UI and not directly, since the parameters
; that go here are meant to be edited using the UI.
;
; Format:
;   [section] ; section goes as a comment
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Trade Nations Reboot"
config/description="Faithful reboot of Trade Nations (Z2Live, Inc., 2011). Phase 1: foundation only — no gameplay content yet. See docs/RECONSTRUCTION.md."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

DataManager="*res://scripts/autoload/data_manager.gd"
TimeManager="*res://scripts/autoload/time_manager.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
GameManager="*res://scripts/autoload/game_manager.gd"
